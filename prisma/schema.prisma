
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum Channel {
  WHATSAPP
  SMS
  EMAIL
  RCS
}

enum SegmentSource {
  AI
  HUMAN
}

enum CampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum CommunicationStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  CLICKED
  CONVERTED
  FAILED
}

enum EventType {
  QUEUED
  SENT
  DELIVERED
  READ
  CLICKED
  CONVERTED
  FAILED
}


model Customer {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  phone       String?
  city        String?
  country     String?   @default("India")
  tags        String[]  @default([])
  totalSpend  Float     @default(0)
  orderCount  Int       @default(0)
  lastOrderAt DateTime?
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Order {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Float
  items      Int      @default(1)
  status     String   @default("completed")
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Segment {
  id          String        @id @default(cuid())
  name        String
  description String?
  ruleJson    Json
  source      SegmentSource @default(HUMAN)
  campaigns   Campaign[]
  createdAt   DateTime      @default(now())
}

model Campaign {
  id              String          @id @default(cuid())
  name            String
  goal            String?
  channel         Channel
  messageTemplate String
  status          CampaignStatus  @default(DRAFT)
  segmentId       String?
  segment         Segment?        @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  audienceSize    Int             @default(0)
  launchedAt      DateTime?
  communications  Communication[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Communication {
  id              String               @id @default(cuid())
  campaignId      String
  campaign        Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId      String
  channel         Channel
  recipient       String
  renderedMessage String
  status          CommunicationStatus  @default(QUEUED)
  statusRank      Int                  @default(0)
  idempotencyKey  String               @unique
  attempts        Int                  @default(0)
  failureReason   String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  clickedAt       DateTime?
  convertedAt     DateTime?
  failedAt        DateTime?
  events          CommunicationEvent[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([campaignId])
  @@index([customerId])
  @@index([status])
}

model CommunicationEvent {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  eventId         String        @unique
  type            EventType
  payload         Json?
  occurredAt      DateTime
  createdAt       DateTime      @default(now())

  @@index([communicationId])
}