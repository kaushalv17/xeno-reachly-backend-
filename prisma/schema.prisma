generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Channel {
  WHATSAPP
  SMS
  EMAIL
  RCS
}

enum SegmentSource {
  AI
  HUMAN
}

enum CampaignStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

enum CommunicationStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  CLICKED
  CONVERTED
  FAILED
}

enum EventType {
  QUEUED
  SENT
  DELIVERED
  READ
  CLICKED
  CONVERTED
  FAILED
}

model Customer {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  phone          String?
  city           String?
  country        String?   @default("India")
  tags           String[]  @default([])
  totalSpend     Float     @default(0)
  orderCount     Int       @default(0)
  lastOrderAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]
  communications Communication[]

  @@index([city])
  @@index([lastOrderAt])
}

model Order {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount     Float
  items      Int      @default(1)
  status     String   @default("completed")
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

model Segment {
  id          String        @id @default(cuid())
  name        String
  description String?
  ruleJson    Json
  source      SegmentSource @default(HUMAN)
  createdAt   DateTime      @default(now())

  campaigns   Campaign[]
}

model Campaign {
  id              String         @id @default(cuid())
  name            String
  goal            String?
  channel         Channel
  messageTemplate String
  status          CampaignStatus @default(DRAFT)
  segmentId       String?
  segment         Segment?       @relation(fields: [segmentId], references: [id])
  audienceSize    Int            @default(0)
  launchedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  communications  Communication[]

  @@index([status])
}

model Communication {
  id              String              @id @default(cuid())
  campaignId      String
  campaign        Campaign            @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId      String
  customer        Customer            @relation(fields: [customerId], references: [id])
  channel         Channel
  recipient       String
  renderedMessage String
  status          CommunicationStatus @default(QUEUED)
  statusRank      Int                 @default(0)
  idempotencyKey  String              @unique
  attempts        Int                 @default(0)
  failureReason   String?

  queuedAt        DateTime            @default(now())
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  clickedAt       DateTime?
  convertedAt     DateTime?
  failedAt        DateTime?

  events          CommunicationEvent[]

  @@index([campaignId])
  @@index([status])
  @@index([customerId])
}

model CommunicationEvent {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  type            EventType
  payload         Json?
  occurredAt      DateTime      @default(now())

  @@index([communicationId])
}